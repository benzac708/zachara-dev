project_name        = "zachara-azlab"
resource_group_name = "zachara-azure-lab-rg"
location            = "East US"
vm_size             = "Standard_B1s"
admin_username      = "labuser"
ssh_public_key_path = "~/.ssh/azure_lab_rsa.pub"

# Tighten this before apply if you know your current public IP.
allowed_ssh_cidr = "0.0.0.0/0"
