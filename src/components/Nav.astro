---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navItems = [
  { href: "/#home", label: "Home", shortLabel: "Home" },
  { href: "/#projects", label: "Projects", shortLabel: "Projects" },
  { href: "/#contact", label: "Contact", shortLabel: "Contact" },
];

const isSinglePage = currentPath === "/";
---

<nav class="border-b border-slate-800 bg-black/80 backdrop-blur sticky top-0 z-50">
  <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2 shrink-0">
      <img src="/icon.svg" alt="zachara.dev" class="w-10 h-10" />
      <span class="text-lg font-bold text-white tracking-tight hidden sm:inline">zachara<span class="text-emerald-400">.dev</span></span>
    </a>
      <div class="flex items-center gap-2 sm:gap-4">
      <div class="flex gap-4 sm:gap-6 text-sm font-medium shrink-0 overflow-x-auto">
        {navItems.map((item) => (
          <a href={item.href} class={isSinglePage ? "text-slate-400 hover:text-white transition" : "text-slate-400 hover:text-white transition"}>
            <span class="hidden sm:inline">{item.label}</span>
            <span class="sm:hidden">{item.shortLabel}</span>
          </a>
        ))}
      </div>
      
    </div>
  </div>
</nav>
