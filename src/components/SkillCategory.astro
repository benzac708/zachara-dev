---
interface Props {
  title: string;
  skills: string[];
}

const { title, skills } = Astro.props;
---

<div class="bg-black border border-slate-800 rounded-lg p-6 hover:border-emerald-400/30 transition">
  <h3 class="text-base font-bold text-white mb-4">{title}</h3>
  <div class="flex flex-wrap gap-2">
    {skills.map((skill) => (
      <span class="px-2 py-1 bg-emerald-400/10 text-emerald-400 text-xs font-mono rounded border border-emerald-400/20">{skill}</span>
    ))}
  </div>
</div>
