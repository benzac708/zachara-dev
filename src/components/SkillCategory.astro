---
interface Props {
  title: string;
  skills: string[];
}

const { title, skills } = Astro.props;
---

<div class="bg-black/50 border border-slate-700 rounded-lg p-4">
  <h3 class="text-sm font-semibold text-emerald-400 mb-3 uppercase tracking-wider">{title}</h3>
  <div class="flex flex-wrap gap-2">
    {skills.map((skill) => (
      <span class="px-2 py-1 bg-slate-700/50 text-slate-300 text-xs rounded">{skill}</span>
    ))}
  </div>
</div>
