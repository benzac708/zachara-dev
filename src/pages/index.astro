---
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProjectCard from "~/components/ProjectCard.astro";
import TechBadge from "~/components/TechBadge.astro";

const techs = [
  "Docker", "K3s (Kubernetes)", "GitHub Actions", "GHCR",
  "Oracle Cloud", "Terraform", "Ubuntu", "Bash", "Traefik", "Tailscale", "UFW", "fail2ban",
];

const projects = [
  {
    title: "zachara-dev",
    description:
      "Personal portfolio site running on K3s on an Oracle Cloud VPS with Docker, GHCR, and GitHub Actions.",
    href: "https://github.com/benzac708/zachara-dev",
    liveHref: "https://zachara.dev",
    tech: ["Astro", "TypeScript", "Bun", "Docker", "K3s"],
    details: [
      "Runs the production website as a lightweight single-node Kubernetes workload",
      "GitHub Actions builds the app, pushes to GHCR, and updates the live deployment",
      "Host access is locked down with Tailscale, UFW, fail2ban, and SSH keys",
    ],
    featured: true,
    live: true,
  },
  {
    title: "aws-lab",
    description:
      "Terraform lab for core AWS infrastructure covering compute, networking, and access controls.",
    href: "https://github.com/benzac708/aws-lab",
    tech: ["Terraform", "AWS", "EC2", "VPC"],
    details: [
      "Builds EC2, networking, and supporting AWS resources from Terraform",
      "Covers VPC layout, subnets, security groups, and infrastructure lifecycle basics",
      "Uses the full Terraform init, plan, apply, and destroy workflow",
    ],
    featured: false,
    live: false,
  },
  {
    title: "azure-lab",
    description:
      "Terraform lab for core Azure infrastructure covering VM, VNet, and network security setup.",
    href: "https://github.com/benzac708/azure-lab",
    tech: ["Terraform", "Azure", "VM", "VNet"],
    details: [
      "Builds Azure VM and networking resources from Terraform",
      "Covers VNet, subnet, NSG, and controlled access patterns",
      "Uses the same full Terraform lifecycle as the AWS lab",
    ],
    featured: false,
    live: false,
  },
  {
    title: "oracle-lab",
    description:
      "Platform repo for safely adopting and managing the existing Oracle Cloud VPS and shared K3s services in place.",
    href: "https://github.com/benzac708/oracle-lab",
    tech: ["Oracle Cloud", "K3s", "Docker", "Bash", "Platform Ops"],
    details: [
      "Separates VPS and shared cluster ownership from the website application repo",
      "Starts with host audit, guarded bootstrap, and incremental platform reconciliation",
      "Covers shared services such as Traefik, Argo CD, cert-manager, and observability",
    ],
    featured: true,
    live: false,
  },
  {
    title: "vps-ops-toolkit",
    description:
      "Bash toolkit for VPS maintenance, guarded reboots, cleanup, and recurring host checks.",
    href: "https://github.com/benzac708/vps-ops-toolkit",
    tech: ["Bash", "K3s", "UFW", "fail2ban"],
    details: [
      "Adds guarded reboot flow with K3s drain and recovery steps",
      "Automates disk, Docker, and package maintenance tasks",
      "Uses systemd timers for recurring updates and host checks",
    ],
    featured: false,
    live: false,
  },
];

const sectionRail = "max-w-4xl mx-auto";
const heroRail = "max-w-4xl mx-auto text-center";
---

<BaseLayout
  title="Bernard Zachara | Cloud / DevOps Enthusiast"
  description="Cloud and DevOps enthusiast building Terraform labs, operating Docker and K3s workloads on an Oracle Cloud VPS, and shipping the live zachara.dev website."
  canonical="https://zachara.dev/"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'zachara.dev',
    url: 'https://zachara.dev',
    author: {
      '@type': 'Person',
      name: 'Bernard Zachara',
      url: 'https://zachara.dev',
      jobTitle: 'DevOps Engineer Student',
      sameAs: ['https://github.com/benzac708'],
      knowsAbout: ['Kubernetes', 'Docker', 'K3s', 'GitHub Actions', 'GHCR', 'Oracle Cloud', 'Traefik', 'Tailscale', 'UFW', 'fail2ban', 'Bash', 'Terraform'],
    },
  })} />

  <main class="flex-1">
    <section id="home" class="scroll-mt-24 px-6 py-20 sm:py-24">
      <div class={heroRail}>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-400 mb-4">Bernard Zachara</p>
          <h1 class="text-4xl sm:text-6xl font-bold text-white leading-tight mb-6">
            Self-taught Cloud/DevOps enthusiast.
          </h1>
          <p class="text-lg sm:text-xl text-slate-400 max-w-2xl mx-auto mb-8">
            Building AWS and Azure Terraform labs while operating Docker and K3s workloads on a live Oracle Cloud VPS.
          </p>
          <div class="flex flex-wrap gap-4 mb-10 justify-center">
            <a href="#projects" class="px-6 py-3 border border-slate-600 hover:border-emerald-400 text-slate-300 hover:text-white font-semibold rounded-lg transition">View Projects</a>
            <a href="#contact" class="px-6 py-3 border border-slate-600 hover:border-emerald-400 text-slate-300 hover:text-white font-semibold rounded-lg transition">Contact</a>
          </div>
          <div class="flex flex-wrap gap-2">
            {techs.map((tech) => <TechBadge name={tech} />)}
          </div>
      </div>
    </section>

    <section id="projects" class="scroll-mt-24 px-6 py-16 border-t border-slate-800">
      <div class={sectionRail}>
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-8 text-center">Projects</h2>
        <p class="text-center text-slate-400 max-w-2xl mx-auto mb-10">
          Live website work, cloud labs, and the Oracle VPS platform split that now separates app delivery from shared infrastructure ownership.
        </p>

        <div class="grid gap-6">
          {projects.map((project) => <ProjectCard {...project} />)}
        </div>
      </div>
    </section>

    <section id="contact" class="scroll-mt-24 px-6 py-16 border-t border-slate-800">
      <div class={sectionRail}>
        <div class="mb-8 text-center">
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Contact</h2>
        </div>

        <div class="flex flex-wrap gap-4 justify-center">
          <a href="mailto:bernard@zachara.dev" class="px-6 py-3 border border-slate-600 hover:border-emerald-400 text-slate-300 hover:text-white font-semibold rounded-lg transition">
            bernard@zachara.dev
          </a>
          <a href="https://github.com/benzac708" target="_blank" rel="noopener" class="px-6 py-3 border border-slate-600 hover:border-emerald-400 text-slate-300 hover:text-white font-semibold rounded-lg transition">
            github.com/benzac708
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
