---
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProjectCard from "~/components/ProjectCard.astro";
import SkillCategory from "~/components/SkillCategory.astro";
import TechBadge from "~/components/TechBadge.astro";
import TimelineItem from "~/components/TimelineItem.astro";

const techs = [
  "Kubernetes", "Docker", "K3s", "GitHub Actions", "GHCR",
  "Oracle Cloud", "Linux", "Python", "Bash", "Traefik", "Tailscale", "UFW", "fail2ban",
];

const infrastructureHighlights = [
  {
    title: "Kubernetes Cluster",
    description: "Single-node K3s cluster running the portfolio and supporting services on one Oracle Cloud VPS",
    icon: "kubernetes",
    metrics: ["K3s", "Traefik", "Single Node"],
  },
  {
    title: "Container Workflow",
    description: "Applications are packaged as Docker images and published to GHCR for repeatable deployments",
    icon: "docker",
    metrics: ["Docker", "GHCR", "Multi-stage Builds"],
  },
  {
    title: "CI Workflow",
    description: "GitHub Actions builds the app, runs smoke checks, and publishes container images",
    icon: "github",
    metrics: ["GitHub Actions", "GHCR", "Smoke Checks"],
  },
  {
    title: "Host Security",
    description: "The VPS uses Tailscale, UFW, and fail2ban to reduce public exposure and protect admin access",
    icon: "linux",
    metrics: ["Tailscale", "UFW", "fail2ban"],
  },
];

const tools = [
  { name: "Docker", icon: "docker" },
  { name: "K3s", icon: "kubernetes" },
  { name: "Traefik", icon: "nginx" },
  { name: "GitHub Actions", icon: "github" },
  { name: "GHCR", icon: "github" },
  { name: "Tailscale", icon: "linux" },
  { name: "UFW", icon: "linux" },
  { name: "fail2ban", icon: "linux" },
];

const projects = [
  {
    title: "cloud-devops-portfolio",
    description:
      "Infrastructure repository for the Oracle Cloud VPS and self-hosted services behind this portfolio. It documents the current Docker, K3s, Traefik, GHCR, GitHub Actions, Tailscale, UFW, and fail2ban setup used to run and secure zachara.dev.",
    href: "https://github.com/benzac708/cloud-devops-portfolio",
    tech: ["Docker", "K3s", "Traefik", "GitHub Actions", "GHCR", "Tailscale"],
    featured: true,
    live: true,
  },
  {
    title: "zachara-dev",
    description:
      "This portfolio site is built with Astro and packaged as a Docker image. GitHub Actions builds and publishes the image to GHCR, and the app is served on the Oracle Cloud VPS through Traefik and K3s.",
    href: "https://github.com/benzac708/zachara-dev",
    tech: ["Astro", "TypeScript", "Bun", "Docker", "K3s", "GHCR"],
    live: true,
  },
  {
    title: "vps-infrastructure",
    description:
      "Self-hosted Ubuntu Oracle Cloud VPS running K3s and multiple containerized applications. It uses Traefik for ingress, Tailscale for secure access, UFW and fail2ban for host security, and shell automation for routine maintenance.",
    href: "https://github.com/benzac708",
    tech: ["K3s", "Traefik", "Tailscale", "UFW", "fail2ban", "Oracle Cloud"],
    live: true,
  },
  {
    title: "cloud-app",
    description:
      "Application deployment example using Docker, K3s, health checks, and Traefik ingress routing. Focused on a simple production-style path from container build to live service.",
    href: "https://github.com/benzac708/cloud-app",
    tech: ["K3s", "Docker", "Traefik", "Python"],
    live: true,
  },
];

const skills = [
  { title: "Containers & Orchestration", skills: ["Docker", "Kubernetes", "K3s", "containerd"] },
  { title: "CI/CD", skills: ["GitHub Actions", "GHCR"] },
  { title: "Cloud Platforms", skills: ["Oracle Cloud", "AWS", "Azure"] },
  { title: "Networking & Security", skills: ["Traefik", "Tailscale", "UFW", "fail2ban"] },
  { title: "Scripting & Languages", skills: ["Bash", "Python", "TypeScript", "YAML"] },
];
---

<BaseLayout
  title="Bernard Zachara | DevOps Engineer"
  description="DevOps engineer building and operating Docker and K3s workloads on an Oracle Cloud VPS with CI/CD and host security."
  canonical="https://zachara.dev/"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'zachara.dev',
    url: 'https://zachara.dev',
    author: {
      '@type': 'Person',
      name: 'Ben Zachara',
      url: 'https://zachara.dev',
      jobTitle: 'DevOps Engineer',
      sameAs: ['https://github.com/benzac708'],
      knowsAbout: ['Kubernetes', 'Docker', 'K3s', 'GitHub Actions', 'GHCR', 'Oracle Cloud', 'Traefik', 'Tailscale', 'UFW', 'fail2ban', 'Linux', 'Python', 'Bash'],
    },
  })} />

  <main class="flex-1">
    <section id="home" class="scroll-mt-24 px-6 py-20 sm:py-24">
      <div class="max-w-5xl mx-auto text-center">
        <div class="max-w-3xl mx-auto">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-400 mb-4">Bernard Zachara</p>
          <h1 class="text-4xl sm:text-6xl font-bold text-white leading-tight mb-6">
            DevOps engineer focused on shipping and operating real infrastructure.
          </h1>
          <p class="text-lg sm:text-xl text-slate-400 max-w-2xl mx-auto mb-8">
            I build and run Docker and K3s workloads on an Oracle Cloud VPS, with GitHub Actions for delivery, Traefik for ingress, and Tailscale, UFW, and fail2ban securing admin access.
          </p>
          <div class="flex flex-wrap gap-4 mb-10 justify-center">
            <a href="/resume-cloud-devops.pdf" download="resume-cloud-devops.pdf" class="px-6 py-3 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold rounded-lg transition flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Download Resume
            </a>
            <a href="#projects" class="px-6 py-3 border border-slate-600 hover:border-emerald-400 text-slate-300 hover:text-white font-semibold rounded-lg transition">View Projects</a>
            <a href="#contact" class="px-6 py-3 border border-slate-600 hover:border-emerald-400 text-slate-300 hover:text-white font-semibold rounded-lg transition">Contact</a>
          </div>
          <div class="flex flex-wrap gap-2">
            {techs.map((tech) => <TechBadge name={tech} />)}
          </div>
        </div>
      </div>
    </section>

    <section id="infrastructure" class="scroll-mt-24 px-6 py-16 border-t border-slate-800">
      <div class="max-w-5xl mx-auto">
        <div class="max-w-3xl mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Infrastructure</h2>
          <p class="text-slate-400 text-lg">
            The site runs on one Oracle Cloud VPS: K3s, Traefik ingress, GHCR-hosted images, GitHub Actions builds, and host controls around SSH and admin paths.
          </p>
        </div>

        <div class="bg-black border border-slate-700 rounded-lg p-6 overflow-x-auto mb-12">
          <svg viewBox="0 0 800 400" class="w-full h-auto max-w-3xl mx-auto">
            <rect width="800" height="400" fill="#0f172a" rx="8" />
            <text x="400" y="30" text-anchor="middle" fill="#34d399" font-size="18" font-weight="bold">Infrastructure Architecture</text>
            <rect x="50" y="60" width="140" height="80" fill="#1e293b" stroke="#34d399" stroke-width="2" rx="6" />
            <text x="120" y="85" text-anchor="middle" fill="#fff" font-size="14" font-weight="bold">Oracle Cloud VPS</text>
            <text x="120" y="105" text-anchor="middle" fill="#94a3b8" font-size="11">Ubuntu 22.04 LTS</text>
            <text x="120" y="120" text-anchor="middle" fill="#94a3b8" font-size="11">ARM64 • 24GB RAM</text>
            <line x1="190" y1="100" x2="250" y2="100" stroke="#34d399" stroke-width="2" marker-end="url(#arrowhead)" />
            <rect x="250" y="60" width="140" height="80" fill="#1e293b" stroke="#34d399" stroke-width="2" rx="6" />
            <text x="320" y="85" text-anchor="middle" fill="#fff" font-size="14" font-weight="bold">K3s Cluster</text>
            <text x="320" y="105" text-anchor="middle" fill="#94a3b8" font-size="11">Lightweight K8s</text>
            <text x="320" y="120" text-anchor="middle" fill="#94a3b8" font-size="11">Traefik Ingress</text>
            <line x1="390" y1="100" x2="450" y2="100" stroke="#34d399" stroke-width="2" marker-end="url(#arrowhead)" />
            <rect x="450" y="60" width="140" height="80" fill="#1e293b" stroke="#34d399" stroke-width="2" rx="6" />
            <text x="520" y="85" text-anchor="middle" fill="#fff" font-size="14" font-weight="bold">Docker Runtime</text>
            <text x="520" y="105" text-anchor="middle" fill="#94a3b8" font-size="11">containerd</text>
            <text x="520" y="120" text-anchor="middle" fill="#94a3b8" font-size="11">Multi-stage Builds</text>
            <line x1="590" y1="100" x2="650" y2="100" stroke="#34d399" stroke-width="2" marker-end="url(#arrowhead)" />
            <rect x="650" y="60" width="120" height="80" fill="#1e293b" stroke="#34d399" stroke-width="2" rx="6" />
            <text x="710" y="85" text-anchor="middle" fill="#fff" font-size="14" font-weight="bold">Applications</text>
            <text x="710" y="105" text-anchor="middle" fill="#94a3b8" font-size="11">Portfolio App</text>
            <text x="710" y="120" text-anchor="middle" fill="#94a3b8" font-size="11">Self-hosted Services</text>
            <rect x="200" y="180" width="400" height="90" fill="#1e293b" stroke="#64748b" stroke-width="1" stroke-dasharray="5,5" rx="6" />
            <text x="400" y="205" text-anchor="middle" fill="#94a3b8" font-size="12" font-weight="bold">CI/CD Pipeline</text>
            <rect x="220" y="220" width="80" height="40" fill="#0f172a" stroke="#34d399" stroke-width="1" rx="4" />
            <text x="260" y="240" text-anchor="middle" fill="#fff" font-size="10">GitHub Actions</text>
            <text x="310" y="242" text-anchor="middle" fill="#64748b" font-size="16">→</text>
            <rect x="330" y="220" width="60" height="40" fill="#0f172a" stroke="#34d399" stroke-width="1" rx="4" />
            <text x="360" y="240" text-anchor="middle" fill="#fff" font-size="10">GHCR</text>
            <text x="400" y="242" text-anchor="middle" fill="#64748b" font-size="16">→</text>
            <rect x="420" y="220" width="60" height="40" fill="#0f172a" stroke="#34d399" stroke-width="1" rx="4" />
            <text x="450" y="240" text-anchor="middle" fill="#fff" font-size="10">kubectl</text>
            <text x="490" y="242" text-anchor="middle" fill="#64748b" font-size="16">→</text>
            <rect x="510" y="220" width="70" height="40" fill="#0f172a" stroke="#34d399" stroke-width="1" rx="4" />
            <text x="545" y="240" text-anchor="middle" fill="#fff" font-size="10">K3s</text>
            <line x1="320" y1="140" x2="320" y2="180" stroke="#64748b" stroke-width="1" stroke-dasharray="3,3" />
            <line x1="545" y1="220" x2="545" y2="200" stroke="#64748b" stroke-width="1" />
            <line x1="545" y1="200" x2="320" y2="200" stroke="#64748b" stroke-width="1" />
            <line x1="320" y1="200" x2="320" y2="180" stroke="#64748b" stroke-width="1" />
            <rect x="50" y="300" width="160" height="70" fill="#1e293b" stroke="#f59e0b" stroke-width="2" rx="6" />
            <text x="130" y="325" text-anchor="middle" fill="#fff" font-size="13" font-weight="bold">Network</text>
            <text x="130" y="345" text-anchor="middle" fill="#94a3b8" font-size="11">Traefik Ingress</text>
            <text x="130" y="360" text-anchor="middle" fill="#94a3b8" font-size="11">HTTPS Routing</text>
            <rect x="240" y="300" width="160" height="70" fill="#1e293b" stroke="#3b82f6" stroke-width="2" rx="6" />
            <text x="320" y="325" text-anchor="middle" fill="#fff" font-size="13" font-weight="bold">Access</text>
            <text x="320" y="345" text-anchor="middle" fill="#94a3b8" font-size="11">Tailscale Mesh</text>
            <text x="320" y="360" text-anchor="middle" fill="#94a3b8" font-size="11">Private Admin Paths</text>
            <rect x="430" y="300" width="160" height="70" fill="#1e293b" stroke="#8b5cf6" stroke-width="2" rx="6" />
            <text x="510" y="325" text-anchor="middle" fill="#fff" font-size="13" font-weight="bold">Registry</text>
            <text x="510" y="345" text-anchor="middle" fill="#94a3b8" font-size="11">GitHub Packages</text>
            <text x="510" y="360" text-anchor="middle" fill="#94a3b8" font-size="11">GHCR Images</text>
            <rect x="620" y="300" width="130" height="70" fill="#1e293b" stroke="#10b981" stroke-width="2" rx="6" />
            <text x="685" y="325" text-anchor="middle" fill="#fff" font-size="13" font-weight="bold">Security</text>
            <text x="685" y="345" text-anchor="middle" fill="#94a3b8" font-size="11">UFW Firewall</text>
            <text x="685" y="360" text-anchor="middle" fill="#94a3b8" font-size="11">fail2ban + SSH Keys</text>
            <defs>
              <marker id="arrowhead" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
                <polygon points="0 0, 10 3, 0 6" fill="#34d399" />
              </marker>
            </defs>
          </svg>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
          {infrastructureHighlights.map((item) => (
            <div class="bg-black border border-slate-700 rounded-lg p-6 hover:border-emerald-400/50 transition">
              <div class="flex items-start gap-4 mb-4">
                <div class="w-12 h-12 rounded-lg bg-emerald-400/10 flex items-center justify-center flex-shrink-0">
                  <img src={`https://cdn.jsdelivr.net/gh/devicons/devicon/icons/${item.icon}/${item.icon}-original.svg`} alt={item.title} class="w-8 h-8" />
                </div>
                <div>
                  <h3 class="text-lg font-bold text-white mb-1">{item.title}</h3>
                  <p class="text-slate-400 text-sm">{item.description}</p>
                </div>
              </div>
              <div class="flex flex-wrap gap-2">
                {item.metrics.map((metric) => <span class="px-2 py-1 bg-slate-700/50 text-slate-300 text-xs font-mono rounded">{metric}</span>)}
              </div>
            </div>
          ))}
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {tools.map((tech) => (
            <div class="flex items-center gap-3 p-3 bg-black/30 border border-slate-700/50 rounded-lg">
              <img src={`https://cdn.jsdelivr.net/gh/devicons/devicon/icons/${tech.icon}/${tech.icon}-original.svg`} alt={tech.name} class="w-6 h-6" />
              <span class="text-slate-300 text-sm font-medium">{tech.name}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="projects" class="scroll-mt-24 px-6 py-16 border-t border-slate-800">
      <div class="max-w-5xl mx-auto">
        <div class="max-w-3xl mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Projects</h2>
          <p class="text-slate-400 text-lg">
            Repositories tied to the work behind this site: infrastructure, deployments, and the app itself.
          </p>
        </div>

        <div class="grid gap-6">
          {projects.map((project) => <ProjectCard {...project} />)}
        </div>
      </div>
    </section>

    <section id="resume" class="scroll-mt-24 px-6 py-16 border-t border-slate-800">
      <div class="max-w-5xl mx-auto">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12">
          <div class="max-w-3xl">
            <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Resume</h2>
            <p class="text-slate-400 text-lg">
              Infrastructure-focused work across containers, CI/CD, cluster operations, and host security.
            </p>
          </div>
          <a href="/resume-cloud-devops.pdf" download="resume-cloud-devops.pdf" class="inline-flex items-center gap-2 px-5 py-2.5 bg-emerald-500 hover:bg-emerald-600 text-white font-medium rounded-lg transition text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Download Resume PDF
          </a>
        </div>

        <section class="mb-12">
          <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
            <span class="w-3 h-0.5 bg-emerald-400 inline-block" />
            Skills
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {skills.map((cat) => <SkillCategory {...cat} />)}
          </div>
        </section>

        <section class="mb-12">
          <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
            <span class="w-3 h-0.5 bg-emerald-400 inline-block" />
            Experience
          </h3>
          <div class="space-y-8">
            <TimelineItem
              title="DevOps Engineer - Self-Directed Projects"
              date="2024 - Present"
              active={true}
              bullets={[
                'Built and maintained a K3s cluster on an Ubuntu-based Oracle Cloud VPS with Traefik ingress',
                'Designed CI/CD pipelines with GitHub Actions for container builds and GHCR publishing',
                'Secured host and admin access with Tailscale, UFW, fail2ban, and SSH keys',
                'Automated maintenance tasks with Bash scripts, cron, and systemd timers',
                'Containerized applications with Docker using multi-stage builds and security best practices',
              ]}
            />
          </div>
        </section>

        <section>
          <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
            <span class="w-3 h-0.5 bg-emerald-400 inline-block" />
            Education & Certifications
          </h3>
          <div class="space-y-4">
            <div class="bg-black border border-slate-700 rounded-lg p-4">
              <div class="flex items-start justify-between gap-4">
                <h4 class="font-semibold text-white">University of Information Technology and Management in Rzeszow</h4>
                <span class="text-sm text-slate-400 whitespace-nowrap">Expected March 2028</span>
              </div>
            </div>
            <div class="bg-black border border-slate-700 rounded-lg p-4">
              <h4 class="font-semibold text-white">Continuous Self-Directed Learning</h4>
              <p class="text-sm text-slate-400 mt-1">
                Cloud architecture, Kubernetes administration, infrastructure as code, and DevOps practices through hands-on projects, labs, and vendor documentation.
              </p>
            </div>
          </div>
        </section>
      </div>
    </section>

    <section id="contact" class="scroll-mt-24 px-6 py-16 border-t border-slate-800">
      <div class="max-w-5xl mx-auto">
        <div class="max-w-3xl mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Contact</h2>
          <p class="text-slate-400 text-lg">
            Open to junior DevOps roles, infrastructure work, and technical conversations around the stack running this site.
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          <a href="mailto:bernard@zachara.dev" class="flex items-center gap-4 p-5 bg-black border border-slate-700 rounded-lg hover:border-emerald-400/50 transition group">
            <div class="w-10 h-10 rounded-full bg-emerald-400/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="text-left">
              <p class="text-sm text-slate-500">Email</p>
              <p class="text-white group-hover:text-emerald-400 transition">bernard@zachara.dev</p>
            </div>
          </a>

          <a href="https://github.com/benzac708" target="_blank" rel="noopener" class="flex items-center gap-4 p-5 bg-black border border-slate-700 rounded-lg hover:border-emerald-400/50 transition group">
            <div class="w-10 h-10 rounded-full bg-emerald-400/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-emerald-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
              </svg>
            </div>
            <div class="text-left">
              <p class="text-sm text-slate-500">GitHub</p>
              <p class="text-white group-hover:text-emerald-400 transition">github.com/benzac708</p>
            </div>
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
