---
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProjectCard from "~/components/ProjectCard.astro";
import TechBadge from "~/components/TechBadge.astro";

const techs = [
  "Docker", "K3s (Kubernetes)", "GitHub Actions", "GHCR",
  "Oracle Cloud", "Ubuntu", "Bash", "Traefik", "Tailscale", "UFW", "fail2ban",
];

const projects = [
  {
    title: "zachara-dev",
    description:
      "This portfolio site. Built with Astro, packaged in Docker, deployed to K3s on an Oracle Cloud VPS.",
    href: "https://github.com/benzac708/zachara-dev",
    tech: ["Astro", "TypeScript", "Bun", "Docker", "K3s"],
    details: [
      "K3s cluster on Oracle Cloud VPS with Traefik ingress",
      "CI/CD: GitHub Actions builds → GHCR → kubectl deploy",
      "Host security: Tailscale, UFW, fail2ban, SSH keys",
      "Systemd timers for auto-updates",
    ],
    featured: true,
    live: true,
  },
  {
    title: "aws-lab",
    description:
      "Terraform labs for AWS — EC2, security group, VPC.",
    href: "https://github.com/benzac708/aws-lab",
    tech: ["Terraform", "AWS", "EC2"],
    details: [
      "EC2 instance provisioning",
      "Security group rules",
      "VPC with public subnet and NAT",
      "init → plan → apply → destroy",
    ],
    featured: false,
    live: false,
  },
  {
    title: "azure-lab",
    description:
      "Terraform labs for Azure — VM, VNet, NSG.",
    href: "https://github.com/benzac708/azure-lab",
    tech: ["Terraform", "Azure", "VM"],
    details: [
      "Virtual machine provisioning",
      "Virtual Network (VNet)",
      "Network Security Group (NSG)",
      "init → plan → apply → destroy",
    ],
    featured: false,
    live: false,
  },
  {
    title: "vps-ops-toolkit",
    description:
      "VPS maintenance scripts — safe reboot with K3s drain, cleanup, security checks.",
    href: "https://github.com/benzac708/vps-ops-toolkit",
    tech: ["Bash", "K3s", "UFW", "fail2ban"],
    details: [
      "Safe reboot with K3s drain/uncordon",
      "Disk and Docker cleanup automation",
      "Security health check script",
      "Auto-update via systemd timers",
    ],
    featured: false,
    live: false,
  },
];

const sectionRail = "max-w-4xl mx-auto";
const heroRail = "max-w-4xl mx-auto text-center";
---

<BaseLayout
  title="Bernard Zachara | Cloud / DevOps Enthusiast"
  description="Cloud and DevOps enthusiast building and operating Docker and K3s workloads on an Oracle Cloud VPS with CI/CD and host security."
  canonical="https://zachara.dev/"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'zachara.dev',
    url: 'https://zachara.dev',
    author: {
      '@type': 'Person',
      name: 'Bernard Zachara',
      url: 'https://zachara.dev',
      jobTitle: 'DevOps Engineer Student',
      sameAs: ['https://github.com/benzac708'],
      knowsAbout: ['Kubernetes', 'Docker', 'K3s', 'GitHub Actions', 'GHCR', 'Oracle Cloud', 'Traefik', 'Tailscale', 'UFW', 'fail2ban', 'Bash', 'Terraform'],
    },
  })} />

  <main class="flex-1">
    <section id="home" class="scroll-mt-24 px-6 py-20 sm:py-24">
      <div class={heroRail}>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-400 mb-4">Bernard Zachara</p>
          <h1 class="text-4xl sm:text-6xl font-bold text-white leading-tight mb-6">
            Self-taught cloud/DevOps enthusiast.
          </h1>
          <p class="text-lg sm:text-xl text-slate-400 max-w-2xl mx-auto mb-8">
            Docker + K3s + GitHub Actions CI/CD on a live VPS. Traefik ingress. Tailscale + UFW for access.
          </p>
          <div class="flex flex-wrap gap-4 mb-10 justify-center">
            <a href="#projects" class="px-6 py-3 border border-slate-600 hover:border-emerald-400 text-slate-300 hover:text-white font-semibold rounded-lg transition">View Projects</a>
            <a href="#contact" class="px-6 py-3 border border-slate-600 hover:border-emerald-400 text-slate-300 hover:text-white font-semibold rounded-lg transition">Contact</a>
          </div>
          <div class="flex flex-wrap gap-2">
            {techs.map((tech) => <TechBadge name={tech} />)}
          </div>
      </div>
    </section>

    <section id="projects" class="scroll-mt-24 px-6 py-16 border-t border-slate-800">
      <div class={sectionRail}>
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-8 text-center">Projects</h2>

        <div class="grid gap-6">
          {projects.map((project) => <ProjectCard {...project} />)}
        </div>
      </div>
    </section>

    <section id="contact" class="scroll-mt-24 px-6 py-16 border-t border-slate-800">
      <div class={sectionRail}>
        <div class="mb-8 text-center">
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Contact</h2>
        </div>

        <div class="flex flex-wrap gap-4 justify-center">
          <a href="mailto:bernard@zachara.dev" class="px-6 py-3 border border-slate-600 hover:border-emerald-400 text-slate-300 hover:text-white font-semibold rounded-lg transition">
            bernard@zachara.dev
          </a>
          <a href="https://github.com/benzac708" target="_blank" rel="noopener" class="px-6 py-3 border border-slate-600 hover:border-emerald-400 text-slate-300 hover:text-white font-semibold rounded-lg transition">
            github.com/benzac708
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>